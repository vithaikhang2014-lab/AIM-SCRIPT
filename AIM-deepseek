-- ESP
local espActive = true
local espObjects = {}

local function getHeadPart(character)
    if character:FindFirstChild("Head") then return character.Head end
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") and (part.Name:lower():find("head") or part.Name:lower():find("skull")) then
            return part
        end
    end
    return character:FindFirstChildWhichIsA("BasePart")
end

local function updateESP()
    for _, v in pairs(espObjects) do pcall(function() v:Destroy() end) end
    espObjects = {}
    
    if not espActive then return end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
            local head = plr.Character.Head
            
            local billboard = Instance.new("BillboardGui")
            billboard.Size = UDim2.new(0, 4, 0, 4)
            billboard.StudsOffset = Vector3.new(0, 1.5, 0)
            billboard.AlwaysOnTop = true
            billboard.Parent = head
            
            local box = Instance.new("Frame")
            box.Size = UDim2.new(0, 4, 0, 4)
            box.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            box.BorderSizePixel = 0
            box.Parent = billboard
            
            local nameTag = Instance.new("BillboardGui")
            nameTag.Size = UDim2.new(0, 120, 0, 25)
            nameTag.StudsOffset = Vector3.new(0, 2.2, 0)
            nameTag.AlwaysOnTop = true
            nameTag.Parent = head
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 1, 0)
            nameLabel.BackgroundTransparency = 0.5
            nameLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            nameLabel.Text = plr.Name
            nameLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
            nameLabel.TextSize = 12
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.Parent = nameTag
            
            table.insert(espObjects, billboard)
            table.insert(espObjects, nameTag)
        end
    end
end

espToggle.MouseButton1Click:Connect(function()
