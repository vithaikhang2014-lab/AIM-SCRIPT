-- Hàm tìm kẻ địch gần nhất theo hướng chuột (chỉ nhắm vào đầu)
local function getClosestEnemyAtCursor()
    local maxDistance = 300 -- Khoảng cách tối đa để aim
    local closestPart = nil
    local closestDistance = maxDistance
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    local rootPart = character.HumanoidRootPart
    local camera = workspace.CurrentCamera
    if not camera then return nil end
    
    -- Lấy hướng từ camera qua chuột
    local mouseRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
    
    -- Duyệt tất cả nhân vật trong workspace
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("Humanoid") and otherChar.Humanoid.Health > 0 then
                local head = otherChar:FindFirstChild("Head")
                if head then
                    -- Kiểm tra xem vị trí đầu có nằm gần tia từ camera không
                    local headPos = head.Position
                    local cameraPos = camera.CFrame.Position
                    local direction = mouseRay.Direction
                    local origin = mouseRay.Origin
                    
                    -- Tính khoảng cách từ điểm đầu đến tia
                    local toHead = headPos - origin
                    local projection = toHead:Dot(direction)
                    local closestPointOnRay = origin + direction * projection
                    local distanceToRay = (headPos - closestPointOnRay).Magnitude
                    
                    -- Nếu nằm trong bán kính 50 unit và trong tầm nhìn
                    if distanceToRay < 50 then
                        local distToPlayer = (rootPart.Position - headPos).Magnitude
                        if distToPlayer < closestDistance then
                            closestDistance = distToPlayer
                            closestPart = head
                        end
                    end
                end
            end
        end
    end
    return closestPart
end

-- Vòng lặp aim (tự động hướng về đầu nếu bật)
RunService.RenderStepped:Connect(function()
    if not aimEnabled then return end
    local targetHead = getClosestEnemyAtCursor()
    if targetHead then
        local camera = workspace.CurrentCamera
        if camera then
            -- Dịch chuyển chuột đến vị trí đầu trên màn hình (ảo, không di chuyển chuột thật nhưng có thể dùng cho công cụ)
            local headScreenPos, onScreen = camera:WorldToScreenPoint(targetHead.Position)
            if onScreen then
                -- Mô phỏng di chuyển chuột (chỉ dành cho môi trường có thể set mouse.X/Y, không hiệu quả trong Roblox thật)
                -- Thay vào đó, bạn có thể gán target cho tool hoặc tự động xoay camera.
                -- Dưới đây là cách đơn giản: cập nhật Mouse.Hit hoặc dùng cho gun.
                -- Lưu ý: Không thể set mouse.X/Y trong Roblox. Để thực sự aim, bạn cần xoay camera.
                -- Tuy nhiên script này minh họa logic tìm đầu, và bạn có thể gắn vào weapon.
                
                -- Nếu có weapon đang trang bị, bạn có thể set mouse.TargetFilter hoặc tự động bắn.
                -- Ở đây tôi chỉ hiển thị debug.
                -- Để đơn giản, nó sẽ in ra tên kẻ địch khi aim vào đầu.
                -- Thay vì fake mouse, bạn nên xoay camera bằng CFrame mới.
            end
        end
    end
end)

