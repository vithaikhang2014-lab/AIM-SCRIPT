-- ESP
local espActive = true
local espObjects = {}
local function getHeadPart(character)
    if character:FindFirstChild("Head") then return character.Head end
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") and (part.Name:lower():find("head") or part.Name:lower():find("skull")) then
            return part
        end
    end
    return character:FindFirstChildWhichIsA("BasePart")
end

local function updateESP()
    if not espActive then
        for _, v in pairs(espObjects) do if v then v:Destroy() end end
        espObjects = {}
        return
    end
    for _, v in pairs(espObjects) do if v then v:Destroy() end end
    espObjects = {}
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character.PrimaryPart then
            local head = getHeadPart(plr.Character)
            if head then
                local bill = Instance.new("BillboardGui")
                bill.Size = UDim2.new(0, 4, 0, 4)
                bill.StudsOffset = Vector3.new(0, 1.5, 0)
                bill.AlwaysOnTop = true
                bill.Parent = head
                local frame = Instance.new("Frame")
                frame.Size = UDim2.new(0, 4, 0, 4)
                frame.BackgroundColor3 = Color3.fromRGB(255, 50, 100)
                frame.BorderSizePixel = 0
                frame.Parent = bill
                table.insert(espObjects, bill)
            end
        end
    end
end

espToggle.MouseButton1Click:Connect(function()
    espActive = not espActive
    if espActive then
        espToggle.Text = "👁️ ESP BẬT"
        espToggle.TextColor3 = Color3.fromRGB(150, 255, 150)
    else
        espToggle.Text = "🚫 ESP TẮT"
        espToggle.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
    updateESP()
end)

-- Aim vào đầu gần nhất trong vùng tròn
local function getClosestHeadInCircle()
    local mousePos = UserInputService:GetMouseLocation()
    local center = Vector2.new(aimZone.AbsolutePosition.X + aimZone.AbsoluteSize.X/2, aimZone.AbsolutePosition.Y + aimZone.AbsoluteSize.Y/2)
    local radius = aimZone.AbsoluteSize.X/2
    
    local bestDist = radius + 1
    local bestPart = nil
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local head = getHeadPart(plr.Character)
            if head then
                local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
                if onScreen then
                    local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if distToCenter < bestDist then
                        bestDist = distToCenter
                        bestPart = head
                    end
                end
            end
        end
    end
    -- Thêm model có đầu nếu muốn (ví dụ: dummy)
    for _, model in pairs(workspace:GetDescendants()) do
        if model:IsA("Model") and model ~= LocalPlayer.Character and model:FindFirstChild("Head") and model.Name:lower():find("dummy") then
            local head = model.Head
            local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
            if onScreen then
                local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                if distToCenter < bestDist then
                    bestDist = distToCenter
                    bestPart = head
                end
            end
        end
    end
    
    return bestPart, bestDist
end

-- Aim liên tục không delay
RunService.RenderStepped:Connect(function()
    -- Cập nhật ESP gần realtime
    updateESP()
    
    -- Chỉ AIM nếu bật và đang giữ chuột phải + góc nhìn thứ nhất
    if aimActive and rightMousePressed and Camera.CameraType == Enum.CameraType.Custom then
        local targetHead,dist = getClosestHeadInCircle()
        if targetHead then
            local targetPos = targetHead.Position
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
        end
    end
    
    -- Cập nhật giao diện
    if rightMousePressed and aiming then
        statusLabel.Text = "🎯 ĐANG AIM ĐẦU..."
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        statusLabel.Text = "🔴 Chuột phải: CHỜ"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

-- Bắt chuột phải
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        rightMousePressed = true
        aiming = true
        -- Kiểm tra góc nhìn thứ nhất
        if Camera.CameraType ~= Enum.CameraType.Custom then
            aiming = false
            statusLabel.Text = "⚠️ Chuyển góc nhìn thứ nhất!"
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        rightMousePressed = false
        aiming = false
    end
end)

-- Khởi tạo
updateESP()
