-- Biến trạng thái
local aimEnabled = false

-- Hàm hiển thị thông báo tạm thời
local function showMessage(msg, isError)
	notification.Text = msg
	notification.TextColor3 = isError and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(100, 255, 100)
	notification.Visible = true
	task.wait(1.5)
	notification.Visible = false
end

-- Hàm bật/tắt AIM
local function toggleAim()
	aimEnabled = not aimEnabled
	aimGui.Visible = aimEnabled
	
	if aimEnabled then
		statusLabel.Text = "Status: ON"
		statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
		toggleButton.BackgroundColor3 = Color3.fromRGB(100, 150, 100)
		showMessage("AIM ENABLED - Press M to disable", false)
	else
		statusLabel.Text = "Status: OFF"
		statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		toggleButton.BackgroundColor3 = Color3.fromRGB(70, 70, 90)
		showMessage("AIM DISABLED - Press M to enable", false)
	end
end

-- Hàm nhắm vào đầu
local function aimAtHead()
	if not aimEnabled then return end
	
	-- Tìm kẻ địch gần nhất (chỉnh sửa team check theo game của bạn)
	local closestEnemy = nil
	local closestDistance = 500 -- Phạm vi tối đa
	
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
			local character = otherPlayer.Character
			local head = character:FindFirstChild("Head")
			if head then
				local headPos, onScreen = camera:WorldToScreenPoint(head.Position)
				local screenCenter = Vector2.new(mouse.ViewSizeX / 2, mouse.ViewSizeY / 2)
				local distance = (Vector2.new(headPos.X, headPos.Y) - screenCenter).Magnitude
				
				if distance < closestDistance and onScreen then
					closestDistance = distance
					closestEnemy = otherPlayer
				end
			end
		end
	end
	
	if closestEnemy and closestEnemy.Character then
		local head = closestEnemy.Character:FindFirstChild("Head")
		if head then
			mouse.TargetFilter = nil -- Đảm bảo có thể nhắm xuyên qua GUI
			-- Di chuyển mouse đến vị trí đầu trên màn hình (yêu cầu MouseButton1Click? Không, chỉ nhắm)
			-- LƯU Ý: RemoteEvent nếu cần bắn tự động, ở đây chỉ nhắm
			-- Để nhắm thực tế, ta set mouse.Target? Không được, chỉ có thể set qua CFrame của camera.
			-- Giải pháp: Gửi sự kiện đến server để nhắm hoặc set CursorPosition (không hỗ trợ).
			-- Cách tốt: Chỉ hiển thị vòng tròn và người chơi tự bắn.
			-- Hoặc dùng mousemove ảo? Roblox không cho phép.
			-- Dưới đây là cách highlight hoặc gửi yêu cầu server (tuỳ game)
			
			-- Ví dụ tạo effect highlight kẻ địch (nếu muốn)
			-- Bạn có thể thêm Outline effect ở đây
		end
	end
end

-- Nhấn phím M để toggle
