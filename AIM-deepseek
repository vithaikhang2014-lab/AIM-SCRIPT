-- Lấy đầu gần nhất trong vùng 400px
local function getClosestHeadInCircle()
    local center = Vector2.new(aimZone.AbsolutePosition.X + aimZone.AbsoluteSize.X/2, aimZone.AbsolutePosition.Y + aimZone.AbsoluteSize.Y/2)
    local radius = aimZone.AbsoluteSize.X/2  -- = 200px
    
    local bestDist = radius + 1
    local bestHead = nil
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local head = getHeadPart(plr.Character)
            if head and head:IsA("BasePart") then
                local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
                if onScreen then
                    local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if distToCenter < bestDist then
                        bestDist = distToCenter
                        bestHead = head
                    end
                end
            end
        end
    end
    
    return bestHead, bestDist
end

-- AIM liên tục, chuẩn đầu
RunService.RenderStepped:Connect(function()
    updateESP()
    updateCrosshairPosition()
    
    if aimActive and rightMousePressed and Camera.CameraType == Enum.CameraType.Custom then
        local targetHead = getClosestHeadInCircle()
        if targetHead then
            local targetPos = targetHead.Position
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
            statusLabel.Text = "🎯 ĐANG AIM ĐẦU TRONG VÙNG 400PX!"
            statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        else
            statusLabel.Text = "⚠️ Không có đầu trong vùng 400px"
            statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
        end
    elseif aimActive and rightMousePressed and Camera.CameraType ~= Enum.CameraType.Custom then
        statusLabel.Text = "❌ Chuyển sang góc nhìn thứ nhất!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
    elseif not rightMousePressed then
        statusLabel.Text = "⚡ Giữ chuột phải để AIM đầu (vùng 400px)"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

